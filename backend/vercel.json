{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
    "crons": [
    {
      "path": "/internal/jobs/paper-ingestion",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/internal/jobs/recommendations",
      "schedule": "0 17 * * *"
    }
  ]
}
